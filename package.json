{
  "name": "token-activity-widget",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "React activity heatmap grid for hosted APIs and custom activity data",
  "license": "MIT",
  "author": "harshii0509",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshii0509/token-activity-widget.git"
  },
  "homepage": "https://github.com/harshii0509/token-activity-widget#readme",
  "bugs": {
    "url": "https://github.com/harshii0509/token-activity-widget/issues"
  },
  "keywords": [
    "activity-widget",
    "react",
    "heatmap",
    "grid",
    "activity",
    "dashboard",
    "embed"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc -p ./tsconfig.json",
    "build:watch": "tsc -p ./tsconfig.json --watch --preserveWatchOutput",
    "test": "npm run build && node --experimental-strip-types --test tests/**/*.test.ts",
    "verify": "npm run build && npm pack --dry-run --cache ./.npm-cache",
    "verify:all": "npm run verify && npm run sandbox:build",
    "sandbox:install": "npm run build && npm --prefix ./sandbox install",
    "sandbox:dev": "npm run build && npm --prefix ./sandbox run dev -- --host 127.0.0.1",
    "sandbox:dev:watch": "npm run build && concurrently -k \"npm run build:watch\" \"npm --prefix ./sandbox run dev -- --host 127.0.0.1\"",
    "sandbox:build": "npm run build && npm --prefix ./sandbox run build",
    "sandbox:smoke": "npm run build && node ./scripts/smoke-sandbox.mjs",
    "sandbox:preview": "npm run sandbox:build && npm --prefix ./sandbox run preview -- --host 127.0.0.1",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
