{
  "name": "@claude-leaderboard/activity-widget-react",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "White-label React activity widget renderer for Claude Leaderboard and custom activity data",
  "license": "MIT",
  "author": "harshii0509",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshii0509/token-activity-widget.git"
  },
  "homepage": "https://github.com/harshii0509/token-activity-widget#readme",
  "bugs": {
    "url": "https://github.com/harshii0509/token-activity-widget/issues"
  },
  "keywords": [
    "activity-widget",
    "react",
    "heatmap",
    "claude-leaderboard",
    "portfolio",
    "embed"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "test": "npm run build && node --experimental-strip-types --test tests/**/*.test.ts",
    "verify": "npm run build && npm pack --dry-run --cache ./.npm-cache",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
